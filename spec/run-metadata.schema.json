      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Name"
    },
    "app_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "App Name"
    },
    "started_at": {
      "title": "Started At",
      "type": "string"
    },
    "completed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "step_count": {
      "minimum": 0,
      "title": "Step Count",
      "type": "integer"
    },
    "total_input_tokens": {
      "minimum": 0,
      "title": "Total Input Tokens",
      "type": "integer"
    },
    "total_output_tokens": {
      "minimum": 0,
      "title": "Total Output Tokens",
      "type": "integer"
    },
    "total_latency_ms": {
      "minimum": 0,
      "title": "Total Latency Ms",
      "type": "number"
    },
